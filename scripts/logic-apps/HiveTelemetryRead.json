{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "dataverseUrl": { "type": "String", "defaultValue": "https://orgc5731d44.crm.dynamics.com" },
      "clientId": { "type": "String" },
      "clientSecret": { "type": "SecureString" },
      "tenantId": { "type": "String" }
    },
    "triggers": {
      "manual": {
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "method": "GET",
          "schema": {}
        }
      }
    },
    "actions": {
      "Get_Telemetry": {
        "type": "Http",
        "inputs": {
          "method": "GET",
          "uri": "@{parameters('dataverseUrl')}/api/data/v9.2/gr_hivereadings?$orderby=gr_readingtimestamp desc&$top=500&$select=gr_weight,gr_internaltemp,gr_batteryvoltage,gr_hivehum,gr_legtemp,gr_hiveid,gr_devicemac,gr_devicename,gr_readingtimestamp,createdon",
          "headers": { "Accept": "application/json", "OData-MaxVersion": "4.0", "OData-Version": "4.0", "Prefer": "odata.maxpagesize=500" },
          "authentication": { "type": "ActiveDirectoryOAuth", "tenant": "@parameters('tenantId')", "audience": "@parameters('dataverseUrl')", "clientId": "@parameters('clientId')", "secret": "@parameters('clientSecret')" }
        },
        "runAfter": {}
      },
      "Response": {
        "type": "Response",
        "kind": "Http",
        "inputs": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" },
          "body": "@body('Get_Telemetry')?['value']"
        },
        "runAfter": { "Get_Telemetry": ["Succeeded"] }
      }
    },
    "outputs": {}
  }
}
